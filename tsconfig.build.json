// Specialized tsconfig to only compile .ts-files in the src dir
{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "allowJs": false,
        "checkJs": false,
        "noEmit": false,
        "declaration": false,
        "types": ["node", "mocha"],
        "moduleResolution": "NodeNext",
        "module": "NodeNext"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts"]
}
